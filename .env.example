# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1

# ─── Security ─────────────────────────────────────────────
JWT_SECRET=trendai_super_secret_key_change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ─── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:<DATABASE_PASSWORD>@localhost:5432/trendai
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30
DB_CONNECT_TIMEOUT=10

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_TTL_TRENDS=300
CACHE_TTL_SONGS=600
CACHE_TTL_USER=3600
CACHE_TTL_DASHBOARD=60

# ─── Firebase Admin ───────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_STORAGE_BUCKET=

# ─── Anthropic Claude ─────────────────────────────────────
ANTHROPIC_API_KEY=ADD_LATER
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=2000

OPENAI_API_KEY=
GROQ_API_KEY=
# ─── YouTube ──────────────────────────────────────────────
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
BACKEND_URL=http://localhost:3000
# ─── Spotify ──────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_MARKET=IN 
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
TOKEN_ENCRYPTION_KEY=
# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_AI_MAX=10
RATE_LIMIT_AI_WINDOW=60000

# ─── Razorpay ────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── RevenueCat ───────────────────────────────────────────
REVENUECAT_WEBHOOK_SECRET=your_secret_string_here

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true
TRENDS_ENABLED=true
SONGS_ENABLED=true
SCRAPE_ENABLED=true

# ─── Facebook Data Deletion ────────────────────────────────
FACEBOOK_APP_SECRET=
FRONTEND_URL=http://localhost:5173
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/youtube/callback

APIFY_API_TOKEN=

# ─── Discovery: NewsData.io ────────────────────────────────
# Free tier: 200 credits/day. Get key at https://newsdata.io
NEWSDATA_API_KEY=

# ─── Discovery: Finnhub ───────────────────────────────────
# Free tier: 60 req/min. Get key at https://finnhub.io
FINNHUB_API_KEY=